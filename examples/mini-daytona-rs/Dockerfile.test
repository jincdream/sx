FROM rust:latest

# Use tsinghua mirror for cargo
ENV RUSTUP_DIST_SERVER=https://mirrors.tuna.tsinghua.edu.cn/rustup
ENV RUSTUP_UPDATE_ROOT=https://mirrors.tuna.tsinghua.edu.cn/rustup/rustup

# Use tsinghua mirror for apt
RUN sed -i 's/deb.debian.org/mirrors.tuna.tsinghua.edu.cn/g' /etc/apt/sources.list.d/debian.sources

WORKDIR /work

# Install required dependencies
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    curl \
    jq \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Add cargo config for tsinghua mirror
RUN mkdir -p $HOME/.cargo && \
    echo '[source.crates-io]\n\
replace-with = "tuna"\n\
\n\
[source.tuna]\n\
registry = "https://mirrors.tuna.tsinghua.edu.cn/git/crates.io-index.git"' > $HOME/.cargo/config.toml

# Require components for checking formats & clippy
RUN rustup component add rustfmt clippy

# Copy project files
COPY . .

# Compile the binary
RUN cargo build --release

# Setup a test directory with Nginx dummy Dockerfile for integration testing
RUN mkdir -p /work/tests/e2e && \
    echo "FROM nginx:alpine\nRUN echo 'Hello Mini Daytona' > /usr/share/nginx/html/index.html" > /work/tests/e2e/Dockerfile.nginx && \
    echo "FROM python:3.9-slim\nRUN echo 'Python works' > /opt/test.txt" > /work/tests/e2e/Dockerfile.python

# Default command: setup and run the e2e bash script
CMD ["./run_e2e.sh"]
